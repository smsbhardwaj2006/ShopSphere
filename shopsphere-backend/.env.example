# Copy this file to .env and fill in your real values.
# Never commit the real .env file to git — it's already in .gitignore.
# This file is for LOCAL DEVELOPMENT only. In production (Railway), you set
# these as real environment variables in Railway's dashboard instead —
# see deployment/RAILWAY_SETUP.md for exact steps.

DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Local MySQL (used when DATABASE_URL below is NOT set) ──
# Create this database yourself first:
#   mysql -u root -p
#   CREATE DATABASE shopsphere CHARACTER SET utf8mb4;
DB_NAME=shopsphere
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_HOST=localhost
DB_PORT=3306

# ── Production database (Railway sets this automatically — leave blank locally) ──
# DATABASE_URL=mysql://user:password@host:port/railway

# Origins allowed to call this API from a browser (your frontend's URL)
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173
